# ============================================
# Environment Variables Example (Dummy Values)
# ============================================

# Server
PORT=8000

# JWT Secret (use a long random string in real env)
JWT_SECRET=your-jwt-secret-here

# MongoDB Connection URL
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/database-name

# Admin Login Credentials (used to seed/authenticate the admin user)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# AI Provider Keys (Gemini is primary; OpenAI is used as a fallback)
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key

# Instagram DM Integration
# The access token and webhook verify token are configured in the admin Meta Settings
# page and stored in the database (the access token is auto-refreshed by the cron below).
# They are intentionally NOT read from env — no INSTAGRAM_ACCESS_TOKEN / INSTAGRAM_VERIFY_TOKEN here.

# Secret that protects the daily token-refresh cron endpoint (GET /api/instagram/refresh-token).
# A random string YOU invent (e.g. `openssl rand -hex 32`). You MUST also set this same value in
# your deploy platform's env vars (Vercel → Project → Settings → Environment Variables). Vercel Cron
# automatically sends it as `Authorization: Bearer <CRON_SECRET>`. If unset, the endpoint is unprotected.
CRON_SECRET=your-random-cron-secret-here
